  },
  "bugs": {
    "url": "https://github.com/mcdonaldajr/signalk-ais-plus-apple-watch/issues"
  },
  "homepage": "https://github.com/mcdonaldajr/signalk-ais-plus-apple-watch#readme",
  "engines": {
    "node": ">=18"
